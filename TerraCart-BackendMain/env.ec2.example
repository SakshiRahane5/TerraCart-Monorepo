# Terra Cart Backend - AWS EC2 Environment Variables
# Copy this file to .env and update with your actual values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=5001
TRUST_PROXY_HOPS=1
COMPRESSION_THRESHOLD_BYTES=1024
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_REQUEST_TIMEOUT_MS=120000

# ============================================
# Database Configuration
# ============================================
# Use MongoDB Atlas connection string for production
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/terra-cart?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_IDLE_TIME_MS=30000
MONGO_CONNECT_TIMEOUT_MS=10000

# Redis is required for horizontal scaling (Socket.IO + shared cache/rate-limit state)
# Example (ElastiCache with TLS): rediss://default:password@your-redis-endpoint:6379
REDIS_URL=

# ============================================
# Security - CRITICAL: Change these in production!
# ============================================
# Generate strong random secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SIGNED_URL_SECRET=your-signed-url-secret-change-this-in-production

# ============================================
# CORS Configuration
# ============================================
# Add your frontend URLs (comma-separated, no spaces)
# Replace with your actual EC2 domain or Elastic IP
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://admin.your-domain.com,https://customer.your-domain.com

# ============================================
# API Base URL
# ============================================
# Your EC2 domain or Elastic IP with HTTPS
API_BASE_URL=https://your-domain.com

# ============================================
# App Update (Optional Fallbacks)
# ============================================
# app-update.json is primary source. These env vars are used as fallback.
APP_API_BASE_URL=https://your-domain.com
LATEST_APP_VERSION=1.0.0
MIN_SUPPORTED_APP_VERSION=1.0.0
FORCE_APP_UPDATE=false
APP_UPDATE_URL=

# ============================================
# File Upload Configuration
# ============================================
ALLOW_PUBLIC_UPLOADS=false
MAX_FILE_SIZE=10

# ============================================
# Rate Limiting
# ============================================
DISABLE_RATE_LIMIT=false
RATE_LIMIT_API=500
RATE_LIMIT_LOGIN=10
RATE_LIMIT_UPLOAD=50

# ============================================
# Security Settings
# ============================================
FORCE_HTTPS=true
SESSION_TIMEOUT=60

# ============================================
# Optional Settings
# ============================================
ENABLE_REQUEST_LOGGING=false
ORDER_AUTO_RELEASE_MINUTES=30
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Firebase Admin (individual service-account fields)
# Keep FIREBASE_PRIVATE_KEY with escaped \n in one line.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_VAPID_KEY=
BACKEND_ENABLE_NOTIFICATION_DEBUG=false
BACKEND_ENABLE_SOCKET_TRACE=false

# ============================================
# Printer Configuration (Optional)
# ============================================
# For KOT printing - set to your printer's IP address
PRINTER_ENABLED=true
PRINTER_IP=192.168.1.151
PRINTER_PORT=9100

# ============================================
# Feature Flags
# ============================================
FEATURE_COSTING_ENABLED=true




























