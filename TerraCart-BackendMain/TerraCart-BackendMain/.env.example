# KOT/BILL printing: who may send to the kitchen printer directly.
# AGENT_ONLY = only the on-site Terra Admin app prints (recommended for production).
# BACKEND_ALLOWED = backend may also send to printer via network (e.g. same LAN).
PRINT_MODE=AGENT_ONLY

# Firebase Admin (individual service-account fields)
# Keep FIREBASE_PRIVATE_KEY with escaped \n in one line.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=

# Optional debug tracing (enable only when diagnosing realtime/notification issues)
BACKEND_ENABLE_NOTIFICATION_DEBUG=false
BACKEND_ENABLE_SOCKET_TRACE=false

# OpenAI (Voice Inventory + Translation + Voice Order)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
