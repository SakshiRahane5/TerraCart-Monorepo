# Backend API URL
# For local development: http://localhost:5001
# For deployed backend: https://terracart-backendmain-2.onrender.com
# VITE_NODE_API_URL=http://localhost:5001
VITE_NODE_API_URL=https://api.terracart.in 
VITE_FALLBACK_API_URL=https://terracart-backend.onrender.com

# Customer Frontend URL (Required for QR code generation)
# For local development: http://localhost:5173
# For deployed frontend: Use your CloudFront or S3 website URL
VITE_CUSTOMER_BASE_URL=https://order.terracart.in

# Finances Panel (BOM, Inventory, Food Cost)
# Set to "true" to show Finances in the sidebar for cart/franchise/super admin
VITE_FEATURE_COSTING_ENABLED=true
